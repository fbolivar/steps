# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tenant por defecto (dev) y dominio raíz de la plataforma (marca blanca)
NEXT_PUBLIC_DEFAULT_TENANT=steps
# NEXT_PUBLIC_ROOT_DOMAIN=stepsseguros.app

# --- Solo servidor (NO exponer con NEXT_PUBLIC_) ---

# Service role (bypasa RLS): requerido para notificaciones al agente. Fase 3.
# Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# Chat IA (Anthropic directa) — Fase 3. Sin esta clave el chat degrada a WhatsApp.
ANTHROPIC_API_KEY=
# Modelo del chat. Default claude-opus-4-8; para FAQ económico: claude-haiku-4-5
# CHAT_MODEL=claude-opus-4-8

# Notificaciones al agente (Fase 3). Cada canal se activa solo si tiene credenciales.
# Email (Resend):
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=
# WhatsApp Business Cloud API (Meta):
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Proveedor de cotización (adaptador). manual = fallback B (por defecto).
# QUOTE_PROVIDER=manual

# Captcha Cloudflare Turnstile (anti-abuso en formularios públicos). Gated:
# sin estas claves el captcha se omite (dev). Con ellas, se exige y verifica.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Secreto HMAC de firma de cotizaciones (cierra el bypass anónimo de la RPC).
# DEBE coincidir con public.app_config.quote_signing_secret en Supabase.
# Generar: openssl rand -hex 32 (y guardar el mismo valor en la BD).
QUOTE_SIGNING_SECRET=

# Google OAuth: se configura en Supabase Dashboard, NO aquí
